{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-mark",
  "version": "0.1.0",
  "identifier": "com.tauri-app.tauri-mark",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "备忘录",
        "width": 900,
        "height": 650,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": false,
        "visible": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "template": "installer.nsi"
      }
    }
  }
}
